    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nconst toPostpone = [];\nconst validDays = ['lundi', 'mardi', 'mercredi', 'jeudi', 'vendredi', 'samedi'];\n\nfor (const row of rows) {\n  const r = row.json;\n  const note = String(r['NOTE'] || '').trim().toLowerCase();\n  \n  let targetDay = null;\n  for (const d of validDays) {\n    const regex = new RegExp('\\\\b' + d + '\\\\b');\n    if (regex.test(note)) { targetDay = d.charAt(0).toUpperCase() + d.slice(1); break; }\n  }\n  \n  const isCanceled = note.includes('annuler') || note.includes('annulé') || note.includes('annule');\n  const livStatut = String(r['Livraison'] || '').trim();\n  const livNorm = livStatut.toLowerCase().normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\");\n  const isEffectuee = livNorm.includes('effectu') || livNorm.includes('livre');\n  \n  if (targetDay && !isCanceled && !isEffectuee) {\n    toPostpone.push({\n      targetTab:            targetDay,\n      \"ID Shopify\":         r['ID Shopify'] || '',\n      \"Réf commande\":       r['Réf commande'] || '',\n      \"Date\":               r['Date'] || '',\n      \"À CLIENT\":           r['À CLIENT'] || '',\n      \"Téléphone\":          r['Téléphone'] || '',\n      \"Lieu de livraison\":  r['Lieu de livraison'] || '',\n      \"Produits\":           r['Produits'] || '',\n      \"Prix TOTAL\":         r['Prix TOTAL'] || '',\n      \"Horaire\":            r['Horaire'] || '',\n      \"NOTE\":               r['NOTE'] || '',\n      \"Livreur\":            r['Livreur'] || '',\n      \"Livraison\":          'Livraison en attente'\n    });\n  }\n}\nreturn toPostpone.map(o => ({ json: o }));\n"
      },
