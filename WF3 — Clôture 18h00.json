    {
      "parameters": {
        "jsCode": "// Extract the fulfillment_order_id from Shopify API response\nconst resp = $input.first().json;\n\nif (resp.error || !resp.fulfillment_orders) {\n  return [];\n}\n\nconst orders = resp.fulfillment_orders;\nif (!orders || orders.length === 0) {\n  return [];\n}\n\nconst openOrder = orders.find(o => o.status === \"open\" || o.status === \"in_progress\");\nif (!openOrder) {\n  return [];\n}\n\nreturn [{ json: { fulfillmentOrderId: String(openOrder.id) } }];\n"
      },
      "id": "676e5967-8cf8-43ae-8860-4c1c7d4e87d6",
      "name": "Extract Fulfillment Order ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5360,
        12048
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://b888b7-aa.myshopify.com/admin/api/2024-01/fulfillments.json",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "shopifyOAuth2Api",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"fulfillment\": {\n    \"message\": \"Livraison effectuée\",\n    \"notify_customer\": false,\n    \"line_items_by_fulfillment_order\": [\n      {\n        \"fulfillment_order_id\": {{ $json.fulfillmentOrderId }}\n      }\n    ]\n  }\n}",
        "options": {
          "timeout": 15000
        }
      },
      "id": "9e216d75-316d-459f-9e00-ebfcffd10b61",
      "name": "Shopify Create Fulfillment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        5584,
        12048
      ],
      "credentials": {
        "shopifyOAuth2Api": {
          "id": "YtTyZZxRWbNOIXt9",
          "name": "Shopify account"
        }
      },
      "continueOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nif (!rows || rows.length === 0) return [];\n\nconst lastItem = rows[rows.length - 1].json;\nconst dateCloture = lastItem._dateCloture || lastItem['Date cl\\u00f4ture'] || '';\nconst stats = {};\n\nfor (const row of rows) {\n  const r = row.json;\n  if (r._summaryOnly) continue;\n  const statut = String(r['Statut Livraison'] || r['Livraison'] || '').trim();\n  const sNorm = statut.toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n  if (!sNorm.includes('effectu') && !(sNorm.includes('livre') && !sNorm.includes('non livre'))) continue;\n\n  const livreur = (r['Livreur'] || 'Non assign\\u00e9').trim();\n  const paiement = String(r['Moyen de paiement'] || 'Esp\\u00e8ces').trim() || 'Esp\\u00e8ces';\n  const montant = parseInt(String(r['Prix Total'] || r['Prix TOTAL'] || '0').replace(/[^0-9]/g, ''), 10) || 0;\n\n  const key = livreur + '||' + paiement;\n  if (!stats[key]) stats[key] = { livreur, paiement, count: 0, total: 0 };\n  stats[key].count++;\n  stats[key].total += montant;\n}\n\nconst result = [];\nfor (const s of Object.values(stats)) {\n  result.push({ json: {\n    'Date livraison': dateCloture, 'Livreur': s.livreur,\n    'Moyen de paiement': s.paiement, 'Nombre de livraison': s.count,\n    'Total r\\u00e9colt\\u00e9': s.total, '_summaryOnly': false,\n    '_dateCloture': dateCloture,\n    '_totalGeneral': lastItem._totalGeneral || 0,\n    '_totalEspeces': lastItem._totalEspeces || 0,\n    '_totalCheque': lastItem._totalCheque || 0,\n    '_totalVirement': lastItem._totalVirement || 0,\n    '_livreurStats': lastItem._livreurStats || '{}'\n  }});\n}\n\n// Toujours retourner 1 item pour que Clear Today Sheet et Send Daily Summary tournent\nif (result.length === 0) {\n  return [{ json: {\n    '_summaryOnly': true, '_dateCloture': dateCloture,\n    '_totalGeneral': lastItem._totalGeneral || 0,\n    '_totalEspeces': lastItem._totalEspeces || 0,\n    '_totalCheque': lastItem._totalCheque || 0,\n    '_totalVirement': lastItem._totalVirement || 0,\n    '_livreurStats': lastItem._livreurStats || '{}'\n  }}];\n}\nreturn result;\n"
      },
