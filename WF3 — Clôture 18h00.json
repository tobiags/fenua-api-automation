      "parameters": {
        "jsCode": "// ===========================================\n// Node: Get Current Day\n// ===========================================\nconst tahitiTime = new Date().toLocaleString('en-US', {timeZone: 'Pacific/Tahiti'});\nconst now = new Date(tahitiTime);\n// getDay() gives 0 for Sunday. We want 1=Monday...7=Sunday\nconst weekday = (now.getDay() === 0 ? 7 : now.getDay());\n\nconst dayTabMap = {\n  1: 'Lundi', 2: 'Mardi', 3: 'Mercredi',\n  4: 'Jeudi', 5: 'Vendredi', 6: 'Samedi'\n};\nconst currentTab = dayTabMap[weekday] || null;\n\nreturn [{\n  json: {\n    isWeekday:  !!currentTab,\n    currentTab: currentTab,\n    weekday:    weekday,\n    dateStr:    (String(now.getDate()).padStart(2, '0') + '/' + String(now.getMonth() + 1).padStart(2, '0') + '/' + now.getFullYear())\n  }\n}];\n"
      },
