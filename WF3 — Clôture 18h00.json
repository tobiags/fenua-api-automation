    {
      "parameters": {
        "jsCode": "\nconst rows = $input.all();\nconst toFulfill = [];\nfor (const row of rows) {\n  const r = row.json;\n  const note = String(r['NOTE'] || '').trim().toLowerCase();\n  const isCanceled = note.includes('annuler') || note.includes('annulé') || note.includes('annule');\n\n  const livStatut = String(r['Livraison'] || '').trim();\n  const livNorm = livStatut.toLowerCase()\n    .normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\"); // enlève les accents\n  const isEffectuee = livNorm.includes('effectu') || livNorm.includes('livre'); // match effectué, livré, livrée\n  if (isEffectuee && !isCanceled) {\n    const orderId = String(r['ID Shopify'] || '').trim();\n    if (orderId && orderId !== '9999999999' && orderId !== 'ID Shopify' \n        && !orderId.includes('[ex:')) {\n      toFulfill.push({ orderId, refCommande: r['Réf commande'] });\n    }\n  }\n}\nif (toFulfill.length === 0) {\n  return [];\n}\nreturn toFulfill.map(o => ({ json: o }));\n"
      },
