        "jsCode": "const rows = $input.all();\nconst toCancel = [];\n\nfor (const row of rows) {\n  const r = row.json;\n  const note = String(r['NOTE'] || '').trim().toLowerCase();\n  const isCanceled = note.includes('annuler') || note.includes('annulé') || note.includes('annule');\n  \n  if (isCanceled) {\n    const orderId = String(r['ID Shopify'] || '').trim();\n    if (orderId && orderId !== '9999999999' && orderId !== 'ID Shopify'\n        && !orderId.includes('[ex:')) {\n      toCancel.push({ orderId, refCommande: r['Réf commande'] });\n    }\n  }\n}\n\nif (toCancel.length === 0) {\n  return [];\n}\nreturn toCancel.map(o => ({ json: o }));\n"
      },
